# ============================================================
# Environment variables — copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# Django core
DEBUG=0
SECRET_KEY=your-very-long-random-secret-key-here-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
ENVIRONMENT=production

# PostgreSQL
POSTGRES_DB=blog_db
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Cache TTL (seconds) for the public post feed
PUBLIC_FEED_CACHE_TTL=30
